# ===========================================
# CONFIGURACIÓN DEL SISTEMA DE INSTRUCTIVOS
# ===========================================
# Copia este archivo a .env y completa con tus credenciales reales
# ===========================================

# -------------------------------------------
# BASE DE DATOS - SQL Server
# -------------------------------------------
DB_SERVER=192.168.19.4
DB_USER=sa
DB_PASSWORD=tu_contraseña_aqui

# Bases de datos
DB_DATABASE=SistGestion
DB_DATABASE_FACTURADOR=Facturador_ASanta_Almahue
DB_DATABASE_DW=DW_Almahue

# -------------------------------------------
# NODE.JS API (server.js)
# -------------------------------------------
NODE_DB_ENCRYPT=false
NODE_DB_TRUST_CERT=true
NODE_PORT=3003

# -------------------------------------------
# PYTHON API (api/main.py)
# -------------------------------------------
PYTHON_DB_DRIVER="ODBC Driver 17 for SQL Server"
PYTHON_PORT=8000

# -------------------------------------------
# APLICACIÓN PHP
# -------------------------------------------
PHP_CHARSET=UTF-8
PHP_SESSION_LIFETIME=3600

# -------------------------------------------
# ENTORNO
# -------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_URL=http://192.168.19.4/instructivo
