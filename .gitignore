# ===========================================
# .gitignore - Sistema de Instructivos
# ===========================================

# -------------------------------------------
# Archivos sensibles (NUNCA commitear)
# -------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
conexion.php
.claude/


# -------------------------------------------
# Dependencias
# -------------------------------------------
/vendor/
/node_modules/

# -------------------------------------------
# Archivos temporales / Backups
# -------------------------------------------
*BCK.php
*BCK1.php
*BCK2.php
*.bak
*.tmp
*.temp
*~
*.swp
*.swo

# -------------------------------------------
# Logs
# -------------------------------------------
logs/
*.log

# -------------------------------------------
# Archivos subidos / Generados
# -------------------------------------------
uploads/
downloads/
*.csv
*.xlsx
*.zip

# -------------------------------------------
# IDE / Editor
# -------------------------------------------
.vscode/
.idea/
*.sublime-*

# -------------------------------------------
# Sistema operativo
# -------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------------------------
# PHP
# -------------------------------------------
composer.lock

# -------------------------------------------
# Node.js
# -------------------------------------------
package-lock.json
npm-debug.log

# -------------------------------------------
# Python
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
pip-log.txt
pip-delete-this-directory.txt
